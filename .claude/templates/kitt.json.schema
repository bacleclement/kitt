{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kitt Project Configuration",
  "description": "Per-project configuration for Kitt workflow skills",
  "type": "object",
  "required": ["kitt", "project", "taskManager", "vcs", "build", "commitFormat"],
  "properties": {
    "kitt": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": { "type": "string", "description": "Kitt version installed" },
        "installedAt": { "type": "string", "format": "date-time" }
      }
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
      }
    },
    "taskManager": {
      "type": "object",
      "required": ["type", "config"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["jira", "linear", "github-issues", "local", "none"]
        },
        "config": {
          "type": "object",
          "properties": {
            "instanceUrl": { "type": "string", "format": "uri" },
            "projectKey": { "type": "string" },
            "statuses": {
              "type": "object",
              "required": ["todo", "inProgress", "review", "done", "blocked"],
              "properties": {
                "todo":       { "type": "string" },
                "inProgress": { "type": "string" },
                "review":     { "type": "string" },
                "done":       { "type": "string" },
                "blocked":    { "type": "string" }
              }
            }
          }
        }
      }
    },
    "vcs": {
      "type": "object",
      "required": ["type", "config"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["github", "gitlab", "bitbucket"]
        },
        "config": {
          "type": "object",
          "required": ["baseBranch"],
          "properties": {
            "account":    { "type": "string" },
            "org":        { "type": "string" },
            "repo":       { "type": "string" },
            "baseBranch": { "type": "string", "default": "main" }
          }
        },
        "worktrees": {
          "type": "object",
          "description": "Optional worktree isolation configuration",
          "properties": {
            "path": {
              "type": "string",
              "description": "Base path for worktrees. Use {{project.name}} as placeholder. Default: ~/worktrees/{{project.name}}",
              "default": "~/worktrees/{{project.name}}"
            },
            "setup": {
              "type": "array",
              "description": "Commands to run after worktree creation. If omitted, auto-detected from project files.",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "build": {
      "type": "object",
      "properties": {
        "test":      { "type": "string", "description": "Use {project} and {pattern} as placeholders" },
        "typecheck": { "type": "string" },
        "lint":      { "type": "string" },
        "build":     { "type": "string" }
      }
    },
    "scopes": {
      "type": "object",
      "description": "Optional app-scoped context for monorepos. Each key is a scope name, value defines the app path and agent globs. Omit entirely for single-app projects (backward compatible).",
      "additionalProperties": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path to the app/service folder in the codebase (e.g. apps/api/services/network)"
          },
          "agents": {
            "type": "array",
            "description": "Glob patterns for agent docs to load when this scope is active. Agents not listed in any scope are always loaded (repo-wide).",
            "items": { "type": "string" }
          }
        }
      }
    },
    "design": {
      "type": "object",
      "description": "Optional design tool integration",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["figma", "zeplin", "none"],
          "description": "Design tool adapter to use"
        },
        "config": {
          "type": "object",
          "properties": {
            "defaultFileKey": {
              "type": "string",
              "description": "Default design file key (e.g. Figma file key from URL)"
            }
          }
        }
      }
    },
    "commitFormat": {
      "type": "object",
      "properties": {
        "pattern": {
          "type": "string",
          "default": "{type}({ticket}): {description}",
          "description": "Use {type}, {ticket}, {description} as placeholders"
        },
        "types": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["feat", "fix", "refactor", "test", "docs", "chore"]
        },
        "coAuthored": {
          "type": "boolean",
          "default": false,
          "description": "If true, add Co-Authored-By to commit body"
        }
      }
    }
  }
}
